<jasperReport name="ListaSeguimientoPago" language="java" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c28245a8-5c65-4422-a8a3-4e3bd298b1b6">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="JDBC Adapter"/>
	<property name="com.jaspersoft.studio.report.description" value=""/>
	<parameter name="nombre_grupo" forPrompting="false" class="java.lang.String"/>
	<parameter name="nombre_profesor" forPrompting="false" class="java.lang.String"/>
	<parameter name="classroom" forPrompting="false" class="java.lang.String"/>
	<parameter name="ruta_imagenes" forPrompting="false" class="java.lang.String"/>
	<parameter name="PeriodoActual" forPrompting="false" class="java.lang.String"/>
	<parameter name="id_teacher" class="java.lang.String"/>
	<parameter name="numMeses" forPrompting="false" class="java.lang.String"/>
	<query language="SQL"><![CDATA[
SELECT students.id_student, students.apellido_paterno_student, students.apellido_materno_student, students.nombre_student, students.telefono1_student, 
payment.id_payment,
payment.register_payment, payment.pay_1, payment.pay_2, payment.pay_3, payment.pay_4, 
payment.pay_5, payment.pay_6, payment.pay_7, payment.payment_status, payment_status.description_status FROM students
INNER JOIN payment ON payment.id_payment = students.id_payment_student
INNER JOIN payment_status ON payment.payment_status = payment_status.id_status
WHERE id_teacher_student = $P{id_teacher}
ORDER BY apellido_paterno_student
]]></query>
