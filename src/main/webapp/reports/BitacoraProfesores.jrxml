	<parameter name="PeriodoActual" forPrompting="false" class="java.lang.String"/>
	<parameter name="ruta_imagenes" forPrompting="false" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
	teachers.id_teacher,
	teachers.apellido_paterno_teacher, 
    teachers.apellido_materno_teacher, 
    teachers.nombre_teacher, 
    grupos.id_group, 
    grupos.id_grade, 
    grade.description_grade , 
    grupos.level_group,  
    grupos.id_category_group, 
	category.description_category ,
    teachers.classroom_teacher FROM teachers
INNER JOIN grupos ON teachers.id_group_teacher = grupos.id_group
INNER JOIN grade ON grupos.id_grade = grade.id_grade
INNER JOIN category ON grupos.id_category_group = category.id_category
ORDER BY grupos.id_group;]]></query>
