<jasperReport name="BitacoraProfesores" language="java" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9c6bcedb-ffb5-4ddd-8060-2e0f6ee28e9b">
