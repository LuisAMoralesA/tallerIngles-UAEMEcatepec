	<query language="SQL"><![CDATA[SELECT students.id_student, students.apellido_paterno_student, students.apellido_materno_student, students.nombre_student, 
users.nom_user, report.id_report, report.first_partial_report, report.second_partial_report, report.avg_report FROM students
INNER JOIN users ON users.id_user = students.id_user_student
INNER JOIN report ON report.id_report = students.id_report_student
WHERE id_teacher_student = $P{id_teacher};]]></query>
